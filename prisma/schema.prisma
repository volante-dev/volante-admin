generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id            String    @id @default(cuid())
  title         String
  titleEn       String?
  slug          String    @unique
  description   String
  descriptionEn String?
  imageUrl      String
  heroColorOverride String?
  heroColorComputed String?
  tags          String[]
  clientName    String?
  sector        String?
  sectorEn      String?
  projectYear   Int?
  projectLocation String?
  projectLocationEn String?
  deliveredServices String[] @default([])
  deliveredServicesEn String[] @default([])
  challenge     String?
  challengeEn   String?
  approach      String?
  approachEn    String?
  results       String?
  resultsEn     String?
  credits       String?
  awards        String?
  awardsEn      String?
  externalUrl   String?
  featured      Boolean   @default(false)
  order         Int       @default(0)
  portfolioSize ProjectPortfolioSize @default(NORMAL)
  portfolioOrder Int      @default(0)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  slides        ProjectSlide[]
}

enum ProjectPortfolioSize {
  NORMAL
  HERO
}

enum ProjectSlideMediaType {
  IMAGE
  VIDEO
}

model ProjectSlide {
  id            String                @id @default(cuid())
  project       Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  order         Int                   @default(0)
  title         String
  titleEn       String?
  contentHtml   String
  contentHtmlEn String?
  mediaType     ProjectSlideMediaType @default(IMAGE)
  mediaUrl      String
  posterUrl     String?
  alt           String?
  altEn         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([projectId, order])
}

model Service {
  id            String  @id @default(cuid())
  title         String
  titleEn       String?
  description   String
  descriptionEn String?
  icon          String?
  order         Int     @default(0)
  active        Boolean @default(true)
}

model StudioValue {
  id            String  @id @default(cuid())
  title         String
  titleEn       String?
  description   String
  descriptionEn String?
  order         Int     @default(0)
  active        Boolean @default(true)

  @@index([active, order])
}

model Testimonial {
  id        String  @id @default(cuid())
  author    String
  company   String
  quote     String
  avatarUrl String?
  order     Int     @default(0)
  active    Boolean @default(true)
}
