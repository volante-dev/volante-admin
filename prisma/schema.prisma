generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id                      String                 @id @default(cuid())
  title                   String
  slug                    String                 @unique
  description             String
  imageUrl                String
  imageAssetId            String?
  imageAsset              MediaAsset?            @relation("ProjectImageAsset", fields: [imageAssetId], references: [id], onDelete: SetNull)
  heroPaletteComputed     String[]               @default([])
  tags                    String[]
  clientName              String?
  sectorEntryId           String?
  sectorEntry             ProjectTaxonomyEntry?  @relation("ProjectSector", fields: [sectorEntryId], references: [id], onDelete: SetNull)
  projectYear             Int?
  locationEntryId         String?
  locationEntry           ProjectTaxonomyEntry?  @relation("ProjectLocation", fields: [locationEntryId], references: [id], onDelete: SetNull)
  deliveredServiceEntries ProjectTaxonomyEntry[] @relation("ProjectDeliveredServices")
  challenge               String?
  approach                String?
  results                 String?
  credits                 String?
  awards                  String?
  externalUrl             String?
  featured                Boolean                @default(false)
  order                   Int                    @default(0)
  portfolioSize           ProjectPortfolioSize   @default(NORMAL)
  portfolioOrder          Int                    @default(0)
  publishedAt             DateTime?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  slides                  ProjectSlide[]
  serviceExamples         ServicePortfolioExample[]
  translations            ProjectTranslation[]
}

model BlogPost {
  id                  String          @id @default(cuid())
  title               String
  eyebrow             String
  slug                String          @unique
  seoDescription      String?
  coverMediaUrl       String
  coverMediaAssetId   String?
  coverMediaAsset     MediaAsset?     @relation("BlogPostCoverMediaAsset", fields: [coverMediaAssetId], references: [id], onDelete: SetNull)
  tags                String[]        @default([])
  publishedAt         DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  blocks              BlogPostBlock[]
  translations        BlogPostTranslation[]

  @@index([publishedAt, createdAt])
}

model SiteRoute {
  id                String   @id
  label             String
  slug              String
  order             Int      @default(0)
  showInHeader      Boolean  @default(true)
  showInFooter      Boolean  @default(true)
  includeInSitemap  Boolean  @default(true)
  sitemapPriority   Float    @default(0.7)
  sitemapFrequency  String   @default("monthly")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  translations      SiteRouteTranslation[]

  @@index([order])
  @@index([showInHeader, order])
  @@index([showInFooter, order])
  @@index([includeInSitemap, order])
}

model SiteLocale {
  code             String   @id
  label            String
  nativeLabel      String
  hreflang         String
  isDefault        Boolean  @default(false)
  enabledInAdmin   Boolean  @default(true)
  publishedOnFront Boolean  @default(false)
  aiEnabled        Boolean  @default(false)
  order            Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([enabledInAdmin, order])
  @@index([publishedOnFront, order])
  @@index([isDefault])
}

enum TranslationSource {
  MANUAL
  AI
}

model ProjectTranslation {
  id             String            @id @default(cuid())
  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId      String
  locale         String
  title          String?
  slug           String?
  description    String?
  challenge      String?
  approach       String?
  results        String?
  awards         String?
  source         TranslationSource @default(MANUAL)
  reviewedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([projectId, locale])
  @@unique([locale, slug])
  @@index([locale])
}

model BlogPostTranslation {
  id             String            @id @default(cuid())
  post           BlogPost          @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId         String
  locale         String
  title          String?
  eyebrow        String?
  slug           String?
  seoDescription String?
  tags           String[]          @default([])
  source         TranslationSource @default(MANUAL)
  reviewedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([postId, locale])
  @@unique([locale, slug])
  @@index([locale])
}

model SiteRouteTranslation {
  id             String            @id @default(cuid())
  route          SiteRoute         @relation(fields: [routeId], references: [id], onDelete: Cascade)
  routeId        String
  locale         String
  label          String?
  slug           String?
  source         TranslationSource @default(MANUAL)
  reviewedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([routeId, locale])
  @@unique([locale, slug])
  @@index([locale])
}

enum BlogPostBlockType {
  RICHTEXT
  IMAGE
  VIDEO
}

model BlogPostBlock {
  id           String            @id @default(cuid())
  post         BlogPost          @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId       String
  order        Int               @default(0)
  type         BlogPostBlockType
  contentHtml   String?
  mediaUrl      String?
  mediaAssetId  String?
  mediaAsset    MediaAsset?       @relation("BlogPostBlockMediaAsset", fields: [mediaAssetId], references: [id], onDelete: SetNull)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  translations  BlogPostBlockTranslation[]

  @@index([postId, order])
}

model BlogPostBlockTranslation {
  id             String            @id @default(cuid())
  block          BlogPostBlock     @relation(fields: [blockId], references: [id], onDelete: Cascade)
  blockId        String
  locale         String
  contentHtml    String?
  source         TranslationSource @default(MANUAL)
  reviewedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([blockId, locale])
  @@index([locale])
}

enum ProjectTaxonomyType {
  SECTOR
  LOCATION
  DELIVERED_SERVICE
}

model ProjectTaxonomyEntry {
  id                       String              @id @default(cuid())
  type                     ProjectTaxonomyType
  label                    String
  normalizedKey            String
  slug                     String?
  icon                     String?
  introEyebrow             String?
  introTitle               String?
  intro                    String?
  active                   Boolean             @default(true)
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  sectorProjects           Project[]           @relation("ProjectSector")
  locationProjects         Project[]           @relation("ProjectLocation")
  deliveredServiceProjects Project[]           @relation("ProjectDeliveredServices")
  translations             ProjectTaxonomyEntryTranslation[]

  @@unique([type, normalizedKey])
  @@unique([type, slug])
  @@index([type, active, label])
}

model ProjectTaxonomyEntryTranslation {
  id             String               @id @default(cuid())
  entry          ProjectTaxonomyEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId        String
  locale         String
  label          String?
  slug           String?
  introEyebrow   String?
  introTitle     String?
  intro          String?
  source         TranslationSource    @default(MANUAL)
  reviewedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([entryId, locale])
  @@index([locale])
}

enum ProjectPortfolioSize {
  NORMAL
  HERO
}

enum ProjectSlideMediaType {
  IMAGE
  VIDEO
}

model ProjectSlide {
  id            String                @id @default(cuid())
  project       Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  order         Int                   @default(0)
  title         String
  contentHtml   String
  mediaType     ProjectSlideMediaType @default(IMAGE)
  mediaUrl      String
  mediaAssetId  String?
  mediaAsset    MediaAsset?           @relation("ProjectSlideMediaAsset", fields: [mediaAssetId], references: [id], onDelete: SetNull)
  posterUrl     String?
  alt           String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  translations  ProjectSlideTranslation[]

  @@index([projectId, order])
}

model ProjectSlideTranslation {
  id             String            @id @default(cuid())
  slide          ProjectSlide      @relation(fields: [slideId], references: [id], onDelete: Cascade)
  slideId        String
  locale         String
  title          String?
  contentHtml    String?
  alt            String?
  source         TranslationSource @default(MANUAL)
  reviewedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([slideId, locale])
  @@index([locale])
}

model Service {
  id                String                    @id @default(cuid())
  title             String
  description       String
  descriptionHtml   String
  icon              String?
  order             Int                       @default(0)
  active            Boolean                   @default(true)
  portfolioExamples ServicePortfolioExample[]
  translations      ServiceTranslation[]
}

model ServiceTranslation {
  id              String            @id @default(cuid())
  service         Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId       String
  locale          String
  title           String?
  description     String?
  descriptionHtml String?
  source          TranslationSource @default(MANUAL)
  reviewedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([serviceId, locale])
  @@index([locale])
}

model ServicePortfolioExample {
  id        String   @id @default(cuid())
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serviceId, projectId])
  @@index([serviceId, order])
}

model StudioValue {
  id            String  @id @default(cuid())
  title         String
  description   String
  order         Int     @default(0)
  active        Boolean @default(true)
  translations  StudioValueTranslation[]

  @@index([active, order])
}

model StudioValueTranslation {
  id             String            @id @default(cuid())
  studioValue    StudioValue       @relation(fields: [studioValueId], references: [id], onDelete: Cascade)
  studioValueId  String
  locale         String
  title          String?
  description    String?
  source         TranslationSource @default(MANUAL)
  reviewedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([studioValueId, locale])
  @@index([locale])
}

model StudioPageContent {
  id                      String      @id
  eyebrow                 String
  title                   String
  intro                   String
  founderOneName          String
  founderOneRole          String
  founderOneDescription   String
  founderOneImageUrl      String
  founderOneImageAssetId  String?
  founderOneImageAsset    MediaAsset? @relation("StudioFounderOneImageAsset", fields: [founderOneImageAssetId], references: [id], onDelete: SetNull)
  founderOneImageAlt      String?
  founderTwoName          String
  founderTwoRole          String
  founderTwoDescription   String
  founderTwoImageUrl      String
  founderTwoImageAssetId  String?
  founderTwoImageAsset    MediaAsset? @relation("StudioFounderTwoImageAsset", fields: [founderTwoImageAssetId], references: [id], onDelete: SetNull)
  founderTwoImageAlt      String?
  historyTitle            String
  historyContentHtml      String
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  translations            StudioPageContentTranslation[]
}

model StudioPageContentTranslation {
  id                      String            @id @default(cuid())
  content                 StudioPageContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  contentId               String
  locale                  String
  eyebrow                 String?
  title                   String?
  intro                   String?
  founderOneName          String?
  founderOneRole          String?
  founderOneDescription   String?
  founderOneImageAlt      String?
  founderTwoName          String?
  founderTwoRole          String?
  founderTwoDescription   String?
  founderTwoImageAlt      String?
  historyTitle            String?
  historyContentHtml      String?
  source                  TranslationSource @default(MANUAL)
  reviewedAt              DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  @@unique([contentId, locale])
  @@index([locale])
}

model PageHeaderContent {
  id        String   @id
  eyebrow   String
  title     String
  intro     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  translations PageHeaderContentTranslation[]
}

model PageHeaderContentTranslation {
  id             String            @id @default(cuid())
  content        PageHeaderContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  contentId      String
  locale         String
  eyebrow        String?
  title          String?
  intro          String?
  source         TranslationSource @default(MANUAL)
  reviewedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([contentId, locale])
  @@index([locale])
}

model HomePageContent {
  id                  String   @id
  eyebrow             String
  title               String
  subheading          String
  primaryCtaLabel     String
  secondaryCtaLabel   String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  translations        HomePageContentTranslation[]
}

model HomePageContentTranslation {
  id                  String            @id @default(cuid())
  content             HomePageContent   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  contentId           String
  locale              String
  eyebrow             String?
  title               String?
  subheading          String?
  primaryCtaLabel     String?
  secondaryCtaLabel   String?
  source              TranslationSource @default(MANUAL)
  reviewedAt          DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([contentId, locale])
  @@index([locale])
}

enum MediaAssetType {
  IMAGE
  VIDEO
}

model MediaAsset {
  id                     String              @id @default(cuid())
  url                    String              @unique
  pathname               String
  mediaType              MediaAssetType
  mimeType               String?
  size                   Int?
  width                  Int?
  height                 Int?
  posterUrl              String?
  posterPathname         String?
  posterMimeType         String?
  posterSize             Int?
  name                   String
  alt                    String?
  tags                   String[]
  active                 Boolean             @default(true)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  projectImages          Project[]           @relation("ProjectImageAsset")
  projectSlideMedia      ProjectSlide[]      @relation("ProjectSlideMediaAsset")
  blogPostCovers         BlogPost[]          @relation("BlogPostCoverMediaAsset")
  blogPostBlockMedia     BlogPostBlock[]     @relation("BlogPostBlockMediaAsset")
  studioFounderOneImages StudioPageContent[] @relation("StudioFounderOneImageAsset")
  studioFounderTwoImages StudioPageContent[] @relation("StudioFounderTwoImageAsset")
  testimonialAvatars     Testimonial[]       @relation("TestimonialAvatarAsset")
  translations           MediaAssetTranslation[]

  @@index([active, mediaType, createdAt])
}

model MediaAssetTranslation {
  id             String            @id @default(cuid())
  asset          MediaAsset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assetId        String
  locale         String
  alt            String?
  tags           String[]          @default([])
  source         TranslationSource @default(MANUAL)
  reviewedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([assetId, locale])
  @@index([locale])
}

model Testimonial {
  id            String      @id @default(cuid())
  author        String
  company       String
  quote         String
  avatarUrl     String?
  avatarAssetId String?
  avatarAsset   MediaAsset? @relation("TestimonialAvatarAsset", fields: [avatarAssetId], references: [id], onDelete: SetNull)
  order         Int         @default(0)
  active        Boolean     @default(true)
}
