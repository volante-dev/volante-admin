generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id                      String                 @id @default(cuid())
  title                   String
  titleEn                 String?
  slug                    String                 @unique
  description             String
  descriptionEn           String?
  imageUrl                String
  imageAssetId            String?
  imageAsset              MediaAsset?            @relation("ProjectImageAsset", fields: [imageAssetId], references: [id], onDelete: SetNull)
  heroPaletteComputed     String[]               @default([])
  tags                    String[]
  clientName              String?
  sectorEntryId           String?
  sectorEntry             ProjectTaxonomyEntry?  @relation("ProjectSector", fields: [sectorEntryId], references: [id], onDelete: SetNull)
  projectYear             Int?
  locationEntryId         String?
  locationEntry           ProjectTaxonomyEntry?  @relation("ProjectLocation", fields: [locationEntryId], references: [id], onDelete: SetNull)
  deliveredServiceEntries ProjectTaxonomyEntry[] @relation("ProjectDeliveredServices")
  challenge               String?
  challengeEn             String?
  approach                String?
  approachEn              String?
  results                 String?
  resultsEn               String?
  credits                 String?
  awards                  String?
  awardsEn                String?
  externalUrl             String?
  featured                Boolean                @default(false)
  order                   Int                    @default(0)
  portfolioSize           ProjectPortfolioSize   @default(NORMAL)
  portfolioOrder          Int                    @default(0)
  publishedAt             DateTime?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  slides                  ProjectSlide[]
}

enum ProjectTaxonomyType {
  SECTOR
  LOCATION
  DELIVERED_SERVICE
}

model ProjectTaxonomyEntry {
  id                       String              @id @default(cuid())
  type                     ProjectTaxonomyType
  label                    String
  labelEn                  String
  normalizedKey            String
  slug                     String?
  icon                     String?
  introEyebrow             String?
  introEyebrowEn           String?
  introTitle               String?
  introTitleEn             String?
  intro                    String?
  introEn                  String?
  active                   Boolean             @default(true)
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  sectorProjects           Project[]           @relation("ProjectSector")
  locationProjects         Project[]           @relation("ProjectLocation")
  deliveredServiceProjects Project[]           @relation("ProjectDeliveredServices")

  @@unique([type, normalizedKey])
  @@unique([type, slug])
  @@index([type, active, label])
}

enum ProjectPortfolioSize {
  NORMAL
  HERO
}

enum ProjectSlideMediaType {
  IMAGE
  VIDEO
}

model ProjectSlide {
  id            String                @id @default(cuid())
  project       Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  order         Int                   @default(0)
  title         String
  titleEn       String?
  contentHtml   String
  contentHtmlEn String?
  mediaType     ProjectSlideMediaType @default(IMAGE)
  mediaUrl      String
  mediaAssetId  String?
  mediaAsset    MediaAsset?           @relation("ProjectSlideMediaAsset", fields: [mediaAssetId], references: [id], onDelete: SetNull)
  posterUrl     String?
  alt           String?
  altEn         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([projectId, order])
}

model Service {
  id                String  @id @default(cuid())
  title             String
  titleEn           String?
  description       String
  descriptionEn     String?
  descriptionHtml   String
  descriptionHtmlEn String?
  icon              String?
  order             Int     @default(0)
  active            Boolean @default(true)
}

model StudioValue {
  id            String  @id @default(cuid())
  title         String
  titleEn       String?
  description   String
  descriptionEn String?
  order         Int     @default(0)
  active        Boolean @default(true)

  @@index([active, order])
}

model StudioPageContent {
  id                      String      @id
  eyebrow                 String
  eyebrowEn               String?
  title                   String
  titleEn                 String?
  intro                   String
  introEn                 String?
  founderOneName          String
  founderOneNameEn        String?
  founderOneRole          String
  founderOneRoleEn        String?
  founderOneDescription   String
  founderOneDescriptionEn String?
  founderOneImageUrl      String
  founderOneImageAssetId  String?
  founderOneImageAsset    MediaAsset? @relation("StudioFounderOneImageAsset", fields: [founderOneImageAssetId], references: [id], onDelete: SetNull)
  founderOneImageAlt      String?
  founderOneImageAltEn    String?
  founderTwoName          String
  founderTwoNameEn        String?
  founderTwoRole          String
  founderTwoRoleEn        String?
  founderTwoDescription   String
  founderTwoDescriptionEn String?
  founderTwoImageUrl      String
  founderTwoImageAssetId  String?
  founderTwoImageAsset    MediaAsset? @relation("StudioFounderTwoImageAsset", fields: [founderTwoImageAssetId], references: [id], onDelete: SetNull)
  founderTwoImageAlt      String?
  founderTwoImageAltEn    String?
  historyTitle            String
  historyTitleEn          String?
  historyContentHtml      String
  historyContentHtmlEn    String?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
}

model PageHeaderContent {
  id        String   @id
  eyebrow   String
  eyebrowEn String?
  title     String
  titleEn   String?
  intro     String?
  introEn   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomePageContent {
  id                  String   @id
  eyebrow             String
  eyebrowEn           String?
  title               String
  titleEn             String?
  subheading          String
  subheadingEn        String?
  primaryCtaLabel     String
  primaryCtaLabelEn   String?
  secondaryCtaLabel   String
  secondaryCtaLabelEn String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

enum MediaAssetType {
  IMAGE
  VIDEO
}

model MediaAsset {
  id                     String              @id @default(cuid())
  url                    String              @unique
  pathname               String
  mediaType              MediaAssetType
  mimeType               String?
  size                   Int?
  width                  Int?
  height                 Int?
  posterUrl              String?
  posterPathname         String?
  posterMimeType         String?
  posterSize             Int?
  name                   String
  alt                    String?
  altEn                  String?
  tags                   String[]
  active                 Boolean             @default(true)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  projectImages          Project[]           @relation("ProjectImageAsset")
  projectSlideMedia      ProjectSlide[]      @relation("ProjectSlideMediaAsset")
  studioFounderOneImages StudioPageContent[] @relation("StudioFounderOneImageAsset")
  studioFounderTwoImages StudioPageContent[] @relation("StudioFounderTwoImageAsset")
  testimonialAvatars     Testimonial[]       @relation("TestimonialAvatarAsset")

  @@index([active, mediaType, createdAt])
}

model Testimonial {
  id            String      @id @default(cuid())
  author        String
  company       String
  quote         String
  avatarUrl     String?
  avatarAssetId String?
  avatarAsset   MediaAsset? @relation("TestimonialAvatarAsset", fields: [avatarAssetId], references: [id], onDelete: SetNull)
  order         Int         @default(0)
  active        Boolean     @default(true)
}
